<?xml version="1.0"?>
<odoo>
  <template id="vpn_download_password" name="VPN Download Password">
    <html>
      <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>VPN Download</title>
        <style>
          * { box-sizing: border-box; margin: 0; padding: 0; }
          body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: linear-gradient(135deg, #ede9fe 0%, #f4f6f9 60%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
          }
          .card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(109,40,217,0.13), 0 2px 8px rgba(0,0,0,0.07);
            padding: 2.5rem 2.2rem;
            width: 100%;
            max-width: 400px;
          }
          .logo-wrap { text-align: center; margin-bottom: 1.6rem; }
          .logo-wrap img { max-width: 130px; height: auto; }
          h2 {
            text-align: center;
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e1b4b;
            margin-bottom: .4rem;
          }
          .subtitle {
            text-align: center;
            color: #6b7280;
            font-size: 0.875rem;
            margin-bottom: 1.4rem;
          }
          .badge-file {
            display: flex;
            align-items: center;
            gap: .5rem;
            background: #f5f3ff;
            border: 1px solid #ddd6fe;
            border-radius: 8px;
            padding: .55rem .9rem;
            margin-bottom: 1.4rem;
            font-size: .875rem;
            color: #5b21b6;
            font-weight: 500;
          }
          .badge-file svg { flex-shrink: 0; }
          .error-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            color: #b91c1c;
            padding: .6rem .9rem;
            font-size: .875rem;
            margin-bottom: 1.1rem;
          }
          label {
            display: block;
            font-size: .875rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: .4rem;
          }
          input[type="password"] {
            width: 100%;
            padding: .65rem .9rem;
            border: 1.5px solid #d1d5db;
            border-radius: 8px;
            font-size: 1rem;
            color: #111827;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            margin-bottom: 1.2rem;
          }
          input[type="password"]:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124,58,237,.15);
          }
          button[type="submit"] {
            width: 100%;
            padding: .7rem;
            background: #7c3aed;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
          }
          button[type="submit"]:hover { background: #6d28d9; }
        </style>
      </head>
      <body>
        <div class="card">
          <div class="logo-wrap">
            <img src="https://www.zebroo.de/web/image/website/1/logo/Zebroo?unique=05cd4b9" alt="Zebroo"/>
          </div>
          <h2>VPN Config Download</h2>
          <p class="subtitle">Enter the password to download your VPN configuration.</p>
          <t t-if="member_name">
            <div class="badge-file">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#7c3aed" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l5 5v13a2 2 0 01-2 2z"/>
              </svg>
              <span t-esc="member_name + '.conf'"/>
            </div>
          </t>
          <t t-if="error">
            <div class="error-box" t-esc="error"/>
          </t>
          <form method="post" t-attf-action="/download/byhash/vpn/#{hash}">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <label for="password">Password</label>
            <input type="password" id="password" name="password" autofocus="1" required="1" placeholder="Enter password"/>
            <button type="submit"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>
              Download
            </button>
          </form>
        </div>
      </body>
    </html>
  </template>
</odoo>
