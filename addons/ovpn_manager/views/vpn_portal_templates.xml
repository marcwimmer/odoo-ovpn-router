<?xml version="1.0"?>
<odoo>
  <template id="vpn_download_password" name="VPN Download Password">
    <t t-call="web.layout">
      <t t-set="head_website">
        <meta charset="utf-8"/>
      </t>
      <div class="container mt-5">
        <div class="row justify-content-center">
          <div class="col-md-4">
            <h3>VPN Config Download</h3>
            <p t-if="member_name">
                            Config: <strong t-esc="member_name"/>
                        </p>
            <div t-if="error" class="alert alert-danger" t-esc="error"/>
            <form method="post" t-attf-action="/download/byhash/vpn/#{hash}">
              <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
              <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" name="password" autofocus="1" required="1"/>
              </div>
              <button type="submit" class="btn btn-primary">Download</button>
            </form>
          </div>
        </div>
      </div>
    </t>
  </template>
</odoo>
